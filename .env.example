# Independent provider selection
# Research: auto | sportradar_soccer | crawler | skip
# Odds:    auto | the_odds_api | crawler | skip
DEFAULT_RESEARCH_PROVIDER=auto
DEFAULT_ODDS_PROVIDER=auto
ENABLE_CRAWLER=true

# Backward-compatible aliases. DEFAULT_* takes precedence when both are set.
DATA_SOURCE_RESEARCH_PROVIDER=auto
DATA_SOURCE_ODDS_PROVIDER=auto
DATA_SOURCE_MATCH_PROVIDER=sportradar_soccer
DATA_SOURCE_CRAWLER_PROVIDER=external_crawler

# Local storage
WCA_SAMPLE_DIR=data/samples
WCA_STORE_PATH=outputs/p0_local_store.json
WCA_RESEARCH_DB_PATH=outputs/research_local.db
RESEARCH_DB_ENABLED=true

# Paid research facts provider
SPORTRADAR_SOCCER_API_KEY=
SPORTRADAR_SOCCER_ACCESS_LEVEL=trial
SPORTRADAR_SOCCER_LANGUAGE=en
SPORTRADAR_SOCCER_BASE_URL=https://api.sportradar.com/soccer
SPORTRADAR_SOCCER_EXTENDED_BASE_URL=https://api.sportradar.com/soccer-extended
SPORTRADAR_SOCCER_EXTENDED_ENABLED=false
SPORTRADAR_SOCCER_TIMEOUT_SECONDS=5.0
SPORTRADAR_SOCCER_WORLD_CUP_COMPETITION_ID=
SPORTRADAR_SOCCER_WORLD_CUP_SEASON_ID=

# Paid odds provider
THE_ODDS_API_KEY=
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_SPORT_KEY=soccer_fifa_world_cup
THE_ODDS_API_REGIONS=eu
THE_ODDS_API_MARKETS=h2h,totals,spreads
THE_ODDS_API_ODDS_FORMAT=decimal
THE_ODDS_API_BOOKMAKERS=

# Optional user-installed crawler fallback
# The directory must expose whoscored_workflow.py for research facts and
# soccerway_odds.py for odds collection.
SPORTS_STABLE_CRAWL_SCRIPTS_DIR=
# Python runtime containing Crawl4AI when the app runtime does not include it.
CRAWLER_PYTHON_PATH=
TARGETED_BACKFILL_CRAWLER_TIMEOUT_SECONDS=600.0

# Generic crawler/news supplement wrapper; not used by targeted backfill.
CRAWLER_COMMAND_PATH=python
CRAWLER_COMMAND_ARGS=scripts/crawler_context_wrapper.py
CRAWLER_TIMEOUT_SECONDS=15.0
# Manual post-match result and player-appearance synchronization
# Open package exposes CLI only; it does not schedule this job.
POST_MATCH_SYNC_ENABLED=false
POST_MATCH_SYNC_INTERVAL_SECONDS=900
POST_MATCH_SYNC_LOOKBACK_HOURS=48
POST_MATCH_SYNC_DELAY_MINUTES=30
POST_MATCH_SYNC_MAX_FIXTURES=20
POST_MATCH_SYNC_PROVIDER=sportradar_soccer
